# 环境变量配置模板
# 复制此文件为 .env.local 并填写真实值
# 注意：.env.local 已被 .gitignore 排除，不会被提交到 Git

# 讯飞 MAAS API 密钥（必填）
# 格式：APIKey:APISecret
XUNFEI_API_KEY=your_api_key_here

# 讯飞 MAAS API 地址（可选，默认如下）
XUNFEI_BASE_URL=https://maas-api.cn-huabei-1.xf-yun.com/v2

# 讯飞 MAAS 模型 ID（可选，默认如下）
XUNFEI_MODEL_ID=xopqwen36v35b
